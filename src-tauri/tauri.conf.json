{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Aether",
    "version": "26.5.1"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": true,
        "execute": true,
        "open": true,
        "scope": [
          { "name": "aether", "cmd": "bash", "args": true },
          { "name": "llama-cli", "cmd": "llama-cli", "args": true },
          { "name": "ollama", "cmd": "ollama", "args": true }
        ]
      },
      "fs": {
        "all": true,
        "scope": ["$HOME/aether/**", "$HOME/.aether/**"]
      },
      "path": { "all": true },
      "os": { "all": true }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "© 2025-2026 Aether Contributors. MIT License.",
      "icon": [],
      "identifier": "com.aether.desktop",
      "targets": ["deb", "appimage", "dmg", "msi"]
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:*; style-src 'self' 'unsafe-inline'"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "title": "Aether — The Local-First Neural Operating Interface",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true
      }
    ]
  }
}
